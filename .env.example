NEXT_PUBLIC_PARENT_COPILOT_V1=1

# Short-report Parent Copilot (Phase D): safe production default is OFF — do not enable for public launch until
# server-side report snapshot exists for /api/parent/copilot-turn (see docs/parent-ai/final-status.md).
NEXT_PUBLIC_ENABLE_PARENT_COPILOT_ON_SHORT=false

# Phase D (optional dev): turn short-report Copilot on locally only after rebuild when testing.
# NEXT_PUBLIC_ENABLE_PARENT_COPILOT_ON_SHORT=true

# Phase D.1: allow unauthenticated client payload for /api/parent/copilot-turn in development only (default on in dev).
# Set to "false" to require student cookie or parent Bearer + studentId (production never allows unauth).
# PARENT_COPILOT_ALLOW_UNAUTH_LOCAL_PAYLOAD=false

# Emergency / controlled environments ONLY — NOT for public production launch.
# When "true", production may execute Copilot against a client-supplied report snapshot (trusts the browser).
# Leave unset or "false" for launch; see docs/parent-ai/copilot-turn-production.md.
# PARENT_COPILOT_ALLOW_CLIENT_PAYLOAD_IN_PRODUCTION=true

# Parent Copilot rollout / quality gates
PARENT_COPILOT_ROLLOUT_STAGE=full
PARENT_COPILOT_LLM_ENABLED=true
PARENT_COPILOT_FORCE_DETERMINISTIC=false
PARENT_COPILOT_KPI_MIN_FLUENCY=75
PARENT_COPILOT_KPI_MIN_GROUNDEDNESS=85
PARENT_COPILOT_KPI_MAX_GENERICNESS=42
PARENT_COPILOT_KPI_MAX_FALLBACK_RATE=0.2
PARENT_COPILOT_KPI_MIN_CLARIFICATION_SUCCESS=0.6

# Optional grounded LLM settings
PARENT_COPILOT_LLM_BASE_URL=https://api.openai.com/v1/responses
PARENT_COPILOT_LLM_MODEL=gpt-4.1-mini
PARENT_COPILOT_LLM_TIMEOUT_MS=9000
PARENT_COPILOT_LLM_API_KEY=

# Parent Report — AI narrative ("סיכום חכם להורה"), server-side only.
# Never use NEXT_PUBLIC_* for API keys; never commit real secrets.
# Vercel: Project Settings → Environment Variables → add for Preview and/or Production, then redeploy.
PARENT_REPORT_NARRATIVE_LLM_PROVIDER=gemini
PARENT_REPORT_NARRATIVE_LLM_MODEL=gemini-2.5-flash
PARENT_REPORT_NARRATIVE_LLM_ENABLED=true
GEMINI_API_KEY=
# Optional overrides (defaults match googleapis Generative Language API):
# PARENT_REPORT_NARRATIVE_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# PARENT_REPORT_NARRATIVE_LLM_TIMEOUT_MS=25000
# PARENT_REPORT_NARRATIVE_FORCE_DETERMINISTIC=true

# Learning-site Supabase (Phase 1 foundation)
NEXT_PUBLIC_LEARNING_SUPABASE_URL=https://ajxwmlwbzxwffrtlfuoe.supabase.co
NEXT_PUBLIC_LEARNING_SUPABASE_ANON_KEY=
LEARNING_SUPABASE_SERVICE_ROLE_KEY=
LEARNING_STUDENT_ACCESS_SECRET=

# Arcade (server): allow spends on disabled/foundation games — ONLY for controlled testing (default off)
# ARCADE_ALLOW_FOUNDATION_ACTIONS=true

# Arcade (client): show raw API JSON on /student/arcade when NODE_ENV=production
# NEXT_PUBLIC_ARCADE_DEBUG=true

# Internal Engine Expert Review Pack admin (`/learning/dev/engine-review`, internal API)
# Vercel: Project Settings → Environment Variables — set for Production (and Preview if needed).
# NEXT_PUBLIC_* must be present at build time. ENGINE_REVIEW_ADMIN_TOKEN is server-only.
NEXT_PUBLIC_ENABLE_ENGINE_REVIEW_ADMIN=true
ENGINE_REVIEW_ADMIN_TOKEN=7479
